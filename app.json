{
  "expo": {
    "name": "Overflow Fleet",
    "slug": "turo-business-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "overflow-rentals",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ECEAF7",
      "dark": {
        "image": "./assets/splash.png",
        "backgroundColor": "#ECEAF7"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overflowrentals.app",
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": {
        "light": "./assets/icon-light.png",
        "dark": "./assets/icon-dark.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.overflowrentals.app",
      "userInterfaceStyle": "automatic"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Overflow Fleet",
      "shortName": "OVF",
      "description": "The all-in-one platform for Turo hosts.",
      "lang": "en",
      "display": "standalone",
      "themeColor": "#593CFB",
      "backgroundColor": "#ECEAF7"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "98bbd266-0134-4dd1-b25e-8c9a80a38d2a"
      }
    },
    "owner": "vavqo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/98bbd266-0134-4dd1-b25e-8c9a80a38d2a"
    }
  }
}
